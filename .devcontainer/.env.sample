# Enable or disable database services by editing this line.
# Available profiles: postgres, trino, starrocks, vault
# Remove a profile name to disable that service.
COMPOSE_PROFILES=postgres,trino,starrocks,vault

# Vault (optional; only in effect when 'vault' is in COMPOSE_PROFILES).
# Flip VAULT_ENABLED to false to bypass Vault entirely, even if VAULT_ADDR
# is set elsewhere in the environment.
# VAULT_ENABLED=true
# VAULT_AUTH_METHOD=token          # or 'approle'
# VAULT_KV_MOUNT=secret
# VAULT_ROLE_ID=                    # required if VAULT_AUTH_METHOD=approle
# VAULT_SECRET_ID=                  # required if VAULT_AUTH_METHOD=approle
